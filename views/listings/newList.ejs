<% layout("/layouts/boilerplate") -%>
<div class="grid grid-cols-12 mt-6">
  <div class="col-span-12 md:col-span-8 md:col-start-3">
    <h3 class="text-3xl font-bold mb-4">Create Your New Listing</h3>
    <form
      method="POST"
      action="/listings"
      novalidate
      class="needs-validation bg-white p-6 rounded-lg shadow"
      enctype="multipart/form-data"
    >
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="mb-4">
        <label for="title" class="block font-bold mb-2">Title:</label>
        <input
          name="listing[title]"
          type="text"
          placeholder="Enter the title"
          class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500"
          required
        />
        <div
          class="form-feedback hidden text-red-500 text-sm mt-1"
          aria-live="polite"
        >
          Please enter the Title
        </div>
      </div>

      <div class="mb-4">
        <label for="description" class="block font-bold mb-2"
          >Description:</label
        >
        <textarea
          name="listing[description]"
          class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500"
          rows="5"
          type="text"
          required
        ></textarea>
        <div
          class="form-feedback hidden text-red-500 text-sm mt-1"
          aria-live="polite"
        >
          Please enter the Description
        </div>
      </div>

      <div class="mb-4">
        <label for="image.url" class="block font-bold mb-2"
          >Upload your Image:</label
        >
        <input
          type="file"
          name="listing[image]"
          class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none"
          placeholder="(Leave empty for default image)"
        />
      </div>

      <div class="grid grid-cols-12 gap-4 mb-4">
        <div class="col-span-12 md:col-span-4">
          <label for="price" class="block font-bold mb-2">Price:</label>
          <input
            name="listing[price]"
            type="number"
            class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="1,500"
            required
          />
          <div
            class="form-feedback hidden text-red-500 text-sm mt-1"
            aria-live="polite"
          >
            Please enter the valid price
          </div>
        </div>

        <div class="col-span-12 md:col-span-8">
          <label for="country" class="block font-bold mb-2">Country:</label>
          <input
            name="listing[country]"
            type="text"
            class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="India"
            required
          />
          <div
            class="form-feedback hidden text-red-500 text-sm mt-1"
            aria-live="polite"
          >
            Please enter the Country name
          </div>
        </div>
      </div>

      <div class="mb-4">
        <label for="location" class="block font-bold mb-2">Location:</label>
        <input
          name="listing[location]"
          type="text"
          class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="Bengaluru, India"
          required
        />
        <div
          class="form-feedback hidden text-red-500 text-sm mt-1"
          aria-live="polite"
        >
          Please enter the Location
        </div>
      </div>

      <button
        type="submit"
        class="w-full px-6 py-2 bg-gray-800 text-white rounded hover:bg-gray-900 font-semibold transition-colors"
      >
        Create Listing
      </button>
    </form>
  </div>
</div>
