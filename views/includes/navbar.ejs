<style>
  .btn-search {
    padding: 0.5rem 1.5rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, rgb(244 63 94), rgb(59 130 246));
    color: #ffffff;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: none;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(244, 63, 94, 0.35);
  }
  .btn-search:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(59, 130, 246, 0.35);
  }
  .btn-search i {
    display: inline;
    margin-right: 0.5rem;
  }
  .search-inp {
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    background-color: rgba(255, 255, 255, 0.96);
    color: #0f172a;
    min-width: 220px;
  }
  .search-inp:focus {
    outline: none;
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.35);
  }
  .navbar-search-wrapper {
    flex: 1;
    display: flex;
    justify-content: center;
    margin: 0 1.5rem;
  }
  .search-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }
  .desktop-brand-title {
    display: none;
    font-size: 1.25rem;
    font-weight: 900;
    color: #f8fafc;
    margin-right: 1.5rem;
    letter-spacing: 0.04em;
    text-shadow: 0 6px 16px rgba(8, 47, 73, 0.55);
  }
  @media (min-width: 768px) {
    .search-form {
      width: auto;
    }
    .navbar-search-wrapper {
      justify-content: flex-start;
    }
  }
  @media (min-width: 1024px) {
    .desktop-brand-title {
      display: block;
    }
  }
</style>

<nav class="flex flex-wrap items-center justify-between sticky top-0 border-b border-white/40 bg-gradient-to-r from-fuchsia-600 via-rose-500 to-orange-400 backdrop-blur-xl z-50 shadow-lg shadow-rose-300/40">
  <div class="w-full px-4 py-3 flex items-center justify-between flex-wrap md:flex-nowrap">
    <a class="text-2xl font-bold text-white hover:text-amber-100 transition-colors" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <span class="desktop-brand-title">PG Finder</span>
    
    <button id="navbar-toggle" class="block md:hidden text-white bg-transparent border-0 p-2 focus:outline-none">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
    
    <div id="navbar-menu" class="hidden md:flex w-full md:w-auto flex-col md:flex-row items-center gap-2 md:gap-6 py-3 md:py-0 bg-rose-600/90 md:bg-transparent rounded-xl md:rounded-none px-2 md:px-0">
      <a class="text-white hover:text-amber-100 px-3 py-2 no-underline block md:inline transition-colors" href="/listings">Explore</a>
      <a class="text-white hover:text-amber-100 px-3 py-2 no-underline block md:inline transition-colors" href="/listings/new">Register PG</a>
      
      <div class="navbar-search-wrapper w-full md:w-auto">
        <form class="search-form" role="search" method="GET" action="/listings">
          <input class="search-inp" type="search" name="location" value="<%= typeof searchLocation !== 'undefined' ? searchLocation : '' %>" placeholder="Search location" aria-label="Search location"/>
          <button class="btn-search" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>
      
      <div class="flex flex-col md:flex-row items-center gap-2 md:gap-4 md:ml-auto">
        <% if(typeof currUser === 'undefined' || !currUser){ %>
          <a class="text-white hover:text-amber-100 px-3 py-2 no-underline transition-colors" href="/signup"><b>Sign up</b></a>
          <a class="text-white hover:text-amber-100 px-3 py-2 no-underline transition-colors" href="/login"><b>Log in</b></a>
        <% } else { %>
          <a class="text-white hover:text-amber-100 px-3 py-2 no-underline transition-colors" href="/listings/favorites"><b>Favorites</b></a>
          <a class="text-white hover:text-amber-100 px-3 py-2 no-underline transition-colors" href="/profile/me"><b>Profile</b></a>
          <a class="text-white hover:text-amber-100 px-3 py-2 no-underline transition-colors" href="/logout"><b>Log out</b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<script>
  document.getElementById('navbar-toggle').addEventListener('click', function() {
    const menu = document.getElementById('navbar-menu');
    menu.classList.toggle('hidden');
  });
</script>
